# ---------- Core ----------
NODE_ENV=development

# ---------- Database ----------
# Local dev via docker-compose:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_analytics?schema=public
REDIS_URL=redis://localhost:6379

# ---------- Auth (NextAuth v5) ----------
# Generate with: openssl rand -base64 48
AUTH_SECRET=replace-me-with-a-long-random-string-at-least-32-chars
AUTH_URL=http://localhost:3000

# ---------- Admin seed (used by prisma/seed.cjs; runs after migrate in Docker / npm start) ----------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Admin

# ---------- Anthropic (Milestone 6+) ----------
# Never put a real key in this file — only in local .env or your host's secret store.
ANTHROPIC_API_KEY=

# ---------- Resend (Milestone 7) ----------
# Never put a real key in this file.
RESEND_API_KEY=
RESEND_FROM="Social Analytics <reports@yourdomain.com>"

# ---------- Google / YouTube OAuth (Milestone 3) ----------
# Never put real OAuth client values in this file.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/oauth/callback
